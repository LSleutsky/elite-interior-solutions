{
  "name": "elite-interior-solutions",
  "description": "Elite Interior Solutions",
  "author": "Lush Sleutsky <lush.sleutsky@gmail.com>",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "basements": "pnpm --filter @elite/basement-solutions dev",
    "kitchens": "pnpm --filter @elite/kitchens-bathrooms dev",
    "build": "pnpm -r build",
    "build:basements": "pnpm --filter @elite/basement-solutions build",
    "build:kitchens": "pnpm --filter @elite/kitchens-bathrooms build",
    "start:basements": "pnpm --filter @elite/basement-solutions start",
    "start:kitchens": "pnpm --filter @elite/kitchens-bathrooms start",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
